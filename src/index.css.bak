/* =========================================================
   SimuAPI – Global Stylesheet
   ========================================================= */

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html, body, #root {
  height: 100%;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
    'Helvetica Neue', Arial, sans-serif;
  background: #f1f5f9;
  color: #1e293b;
  font-size: 14px;
  line-height: 1.5;
}

/* =========================================================
   Layout
   ========================================================= */

.app {
  display: flex;
  flex-direction: column;
  min-height: 100%;
}

.main-content {
  flex: 1;
}

.page {
  padding: 32px 24px;
  max-width: 1200px;
  margin: 0 auto;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}

.page-title {
  font-size: 22px;
  font-weight: 700;
  color: #0f172a;
}

/* =========================================================
   Navbar
   ========================================================= */

.navbar {
  background: #0f172a;
  color: #f8fafc;
  height: 56px;
  display: flex;
  align-items: center;
  padding: 0 24px;
  gap: 0;
  border-bottom: 1px solid #1e293b;
}

.navbar-brand {
  font-size: 18px;
  font-weight: 800;
  color: #38bdf8;
  text-decoration: none;
  letter-spacing: -0.5px;
  margin-right: 40px;
}

.navbar-brand span {
  color: #f8fafc;
}

.navbar-links {
  display: flex;
  gap: 4px;
  align-items: center;
}

.navbar-links a {
  color: #94a3b8;
  text-decoration: none;
  padding: 6px 14px;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  transition: background 0.15s, color 0.15s;
}

.navbar-links a:hover {
  color: #f8fafc;
  background: #1e293b;
}

.navbar-links a.active {
  color: #38bdf8;
  background: #1e293b;
}

/* =========================================================
   Buttons
   ========================================================= */

.btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  transition: background 0.15s, box-shadow 0.15s;
  text-decoration: none;
  white-space: nowrap;
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-primary {
  background: #2563eb;
  color: #fff;
}

.btn-primary:hover:not(:disabled) {
  background: #1d4ed8;
}

.btn-danger {
  background: #dc2626;
  color: #fff;
}

.btn-danger:hover:not(:disabled) {
  background: #b91c1c;
}

.btn-secondary {
  background: #e2e8f0;
  color: #334155;
}

.btn-secondary:hover:not(:disabled) {
  background: #cbd5e1;
}

.btn-ghost {
  background: transparent;
  color: #64748b;
  border: 1px solid #e2e8f0;
}

.btn-ghost:hover:not(:disabled) {
  background: #f8fafc;
  color: #1e293b;
}

.btn-sm {
  padding: 5px 10px;
  font-size: 12px;
}

.btn-upgrade {
  background: linear-gradient(135deg, #a78bfa, #6d28d9);
  color: #fff;
  border: none;
}

.btn-upgrade:hover:not(:disabled) {
  background: linear-gradient(135deg, #8b5cf6, #5b21b6);
  box-shadow: 0 2px 8px rgba(109, 40, 217, 0.3);
}

/* =========================================================
   Cards
   ========================================================= */

.card {
  background: #fff;
  border-radius: 10px;
  padding: 24px;
  box-shadow: 0 1px 4px rgba(0,0,0,.06), 0 0 0 1px rgba(0,0,0,.04);
}

/* =========================================================
   Tables
   ========================================================= */

.table-wrapper {
  background: #fff;
  border-radius: 10px;
  box-shadow: 0 1px 4px rgba(0,0,0,.06), 0 0 0 1px rgba(0,0,0,.04);
  overflow: hidden;
}

table {
  width: 100%;
  border-collapse: collapse;
}

thead th {
  background: #f8fafc;
  padding: 11px 16px;
  text-align: left;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  border-bottom: 1px solid #e2e8f0;
}

tbody td {
  padding: 12px 16px;
  border-bottom: 1px solid #f1f5f9;
  color: #1e293b;
  vertical-align: middle;
}

tbody tr:last-child td {
  border-bottom: none;
}

tbody tr:hover td {
  background: #f8fafc;
}

.table-actions {
  display: flex;
  gap: 8px;
  align-items: center;
}

/* =========================================================
   Forms
   ========================================================= */

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.form-grid .full-width {
  grid-column: 1 / -1;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-group label {
  font-size: 13px;
  font-weight: 600;
  color: #374151;
}

.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 8px 12px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 14px;
  font-family: inherit;
  background: #fff;
  color: #1e293b;
  transition: border-color 0.15s, box-shadow 0.15s;
  outline: none;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: #2563eb;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.form-group textarea {
  resize: vertical;
  font-family: 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', monospace;
  font-size: 13px;
  line-height: 1.6;
}

.form-hint {
  font-size: 11px;
  color: #94a3b8;
  margin-top: 2px;
}

.form-actions {
  display: flex;
  gap: 12px;
  margin-top: 28px;
  padding-top: 20px;
  border-top: 1px solid #f1f5f9;
}

.checkbox-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.checkbox-row input[type="checkbox"] {
  width: 16px;
  height: 16px;
  cursor: pointer;
}

.checkbox-row label {
  font-size: 13px;
  font-weight: 500;
  color: #374151;
  cursor: pointer;
}

/* =========================================================
   Badges
   ========================================================= */

.badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

/* Method badges */
.badge-get    { background: #dbeafe; color: #1d4ed8; }
.badge-post   { background: #dcfce7; color: #15803d; }
.badge-put    { background: #fef9c3; color: #a16207; }
.badge-delete { background: #fee2e2; color: #b91c1c; }
.badge-patch  { background: #ede9fe; color: #6d28d9; }

/* Status badges */
.badge-2xx { background: #dcfce7; color: #15803d; }
.badge-3xx { background: #fef9c3; color: #a16207; }
.badge-4xx { background: #fee2e2; color: #b91c1c; }
.badge-5xx { background: #fce7f3; color: #be185d; }

/* =========================================================
   Alerts
   ========================================================= */

.alert {
  padding: 12px 16px;
  border-radius: 6px;
  font-size: 13px;
  margin-bottom: 16px;
  border: 1px solid transparent;
}

.alert-error {
  background: #fef2f2;
  color: #dc2626;
  border-color: #fecaca;
}

.alert-success {
  background: #f0fdf4;
  color: #16a34a;
  border-color: #bbf7d0;
}

.alert-info {
  background: #eff6ff;
  color: #2563eb;
  border-color: #bfdbfe;
}

.alert-warning {
  background: #fffbeb;
  color: #b45309;
  border-color: #fde68a;
}

/* =========================================================
   Misc
   ========================================================= */

.loading {
  text-align: center;
  padding: 64px 24px;
  color: #94a3b8;
  font-size: 15px;
}

.empty-state {
  text-align: center;
  padding: 64px 24px;
  color: #94a3b8;
}

.empty-state p {
  margin-top: 8px;
  font-size: 13px;
}

code {
  font-family: 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', monospace;
  background: #f1f5f9;
  padding: 2px 5px;
  border-radius: 3px;
  font-size: 12px;
  color: #475569;
}

.mono {
  font-family: 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', monospace;
  font-size: 12px;
}

.text-muted {
  color: #94a3b8;
}

.text-danger {
  color: #dc2626;
}

.curl-box {
  background: #0f172a;
  color: #7dd3fc;
  padding: 12px 16px;
  border-radius: 6px;
  font-family: 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', monospace;
  font-size: 12px;
  white-space: pre-wrap;
  word-break: break-all;
  margin-top: 8px;
}

/* Expandable log row */
.log-body {
  background: #f8fafc;
  padding: 12px;
  border-radius: 6px;
  font-family: 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', monospace;
  font-size: 12px;
  white-space: pre-wrap;
  word-break: break-all;
  color: #475569;
  max-height: 200px;
  overflow-y: auto;
}

/* Filter bar */
.filter-bar {
  display: flex;
  gap: 12px;
  align-items: center;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.filter-bar select,
.filter-bar input {
  padding: 7px 11px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 13px;
  background: #fff;
  outline: none;
  color: #1e293b;
}

.filter-bar select:focus,
.filter-bar input:focus {
  border-color: #2563eb;
  box-shadow: 0 0 0 2px rgba(37,99,235,.1);
}

.pagination {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-top: 16px;
  justify-content: flex-end;
  font-size: 13px;
  color: #64748b;
}

/* =========================================================
   Navbar – right section (auth)
   ========================================================= */

.navbar-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 10px;
}

.navbar-user {
  color: #cbd5e1;
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.navbar-btn {
  color: #cbd5e1 !important;
  border-color: #334155 !important;
}

.navbar-btn:hover {
  color: #f8fafc !important;
}

/* =========================================================
   Plan badges
   ========================================================= */

.plan-badge {
  display: inline-block;
  padding: 1px 7px;
  border-radius: 4px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.plan-free {
  background: #e2e8f0;
  color: #475569;
}

.plan-pro {
  background: linear-gradient(135deg, #a78bfa, #6d28d9);
  color: #fff;
}

/* =========================================================
   Auth pages
   ========================================================= */

.auth-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 56px);
  padding: 24px;
  background: #f1f5f9;
}

.auth-card {
  background: #fff;
  border-radius: 12px;
  padding: 40px 36px;
  width: 100%;
  max-width: 420px;
  box-shadow: 0 4px 24px rgba(0,0,0,.08), 0 0 0 1px rgba(0,0,0,.04);
}

.auth-title {
  font-size: 24px;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 4px;
}

.auth-subtitle {
  font-size: 14px;
  color: #64748b;
  margin-bottom: 24px;
}

.auth-footer {
  text-align: center;
  font-size: 13px;
  color: #64748b;
  margin-top: 20px;
}

.auth-footer a {
  color: #2563eb;
  text-decoration: none;
  font-weight: 600;
}

.auth-footer a:hover {
  text-decoration: underline;
}

/* =========================================================
   Scenario Builder
   ========================================================= */

.scenario-builder {
  margin-top: 24px;
}

.scenario-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.scenario-header h3 {
  font-size: 16px;
  font-weight: 700;
  color: #0f172a;
}

.scenario-header-actions {
  display: flex;
  gap: 8px;
  align-items: center;
}

.scenario-card {
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
}

.scenario-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #f8fafc;
  cursor: pointer;
  user-select: none;
  transition: background 0.15s;
}

.scenario-card-header:hover {
  background: #f1f5f9;
}

.scenario-card-title {
  display: flex;
  align-items: center;
  gap: 6px;
  flex: 1;
  min-width: 0;
}

.scenario-expand {
  font-size: 12px;
  color: #64748b;
  width: 16px;
}

.scenario-name {
  font-weight: 600;
  font-size: 13px;
  color: #1e293b;
}

.scenario-card-body {
  padding: 16px;
  border-top: 1px solid #e2e8f0;
}

/* Conditions */

.conditions-section {
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid #f1f5f9;
}

.conditions-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.conditions-header label {
  font-size: 13px;
  font-weight: 600;
  color: #374151;
}

.condition-row {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-bottom: 8px;
}

.condition-row select,
.condition-row input {
  padding: 6px 10px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 13px;
  background: #fff;
  color: #1e293b;
  outline: none;
}

.condition-row select:focus,
.condition-row input:focus {
  border-color: #2563eb;
  box-shadow: 0 0 0 2px rgba(37,99,235,.1);
}

.condition-row select:first-child {
  width: 130px;
  flex-shrink: 0;
}

.condition-row select:nth-child(3) {
  width: 100px;
  flex-shrink: 0;
}

.condition-row input {
  flex: 1;
  min-width: 0;
}

/* Header input rows (response headers editor) */
.header-input-row {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-bottom: 6px;
}

.header-input-row input {
  flex: 1;
  min-width: 0;
  padding: 6px 10px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 13px;
  font-family: 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', monospace;
  background: #fff;
  color: #1e293b;
  outline: none;
}

.header-input-row input:focus {
  border-color: #2563eb;
  box-shadow: 0 0 0 2px rgba(37,99,235,.1);
}

.header-input-row input:first-child {
  flex: 0 0 40%;
}

.btn-guid-active {
  background: #6d28d9;
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.03em;
}

.btn-guid-active:hover:not(:disabled) {
  background: #5b21b6;
}

/* Template dropdown */

.template-dropdown {
  position: relative;
}

.template-menu {
  display: none;
  position: absolute;
  top: 100%;
  right: 0;
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  box-shadow: 0 4px 12px rgba(0,0,0,.1);
  min-width: 200px;
  z-index: 10;
  padding: 4px 0;
  margin-top: 4px;
}

.template-dropdown:hover .template-menu,
.template-dropdown:focus-within .template-menu {
  display: block;
}

.template-item {
  display: block;
  width: 100%;
  padding: 8px 14px;
  border: none;
  background: transparent;
  text-align: left;
  font-size: 13px;
  color: #1e293b;
  cursor: pointer;
  transition: background 0.1s;
}

.template-item:hover {
  background: #f1f5f9;
}

/* =========================================================
   Dashboard layout (sidebar + main)
   ========================================================= */

.dashboard-layout {
  display: flex;
  min-height: calc(100vh - 56px);
}

.dashboard-layout > .page {
  flex: 1;
  min-width: 0;
}

/* =========================================================
   Collection Sidebar
   ========================================================= */

.collection-sidebar {
  width: 240px;
  flex-shrink: 0;
  background: #fff;
  border-right: 1px solid #e2e8f0;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.sidebar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 16px 12px;
  border-bottom: 1px solid #f1f5f9;
}

.sidebar-header h3 {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
}

.sidebar-nav {
  padding: 8px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sidebar-item-wrapper {
  position: relative;
}

.sidebar-item {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  padding: 8px 12px;
  border: none;
  border-radius: 6px;
  background: transparent;
  font-size: 13px;
  color: #475569;
  cursor: pointer;
  text-align: left;
  transition: background 0.15s, color 0.15s;
}

.sidebar-item:hover {
  background: #f1f5f9;
  color: #1e293b;
}

.sidebar-item.active {
  background: #eff6ff;
  color: #2563eb;
  font-weight: 600;
}

.sidebar-item-icon {
  font-size: 14px;
  flex-shrink: 0;
}

.sidebar-item-label {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sidebar-item-count {
  font-size: 11px;
  color: #94a3b8;
  background: #f1f5f9;
  padding: 1px 6px;
  border-radius: 10px;
  flex-shrink: 0;
}

.team-badge {
  margin-left: 4px;
  font-size: 12px;
  cursor: default;
}

.sidebar-item-menu {
  position: absolute;
  right: 4px;
  top: 50%;
  transform: translateY(-50%);
  display: none;
  border: none;
  background: transparent;
  cursor: pointer;
  font-size: 16px;
  color: #94a3b8;
  padding: 2px 6px;
  border-radius: 4px;
}

.sidebar-item-wrapper:hover .sidebar-item-menu {
  display: block;
}

.sidebar-item-menu:hover {
  background: #e2e8f0;
  color: #475569;
}

.sidebar-context-menu {
  position: absolute;
  right: 4px;
  top: 100%;
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  box-shadow: 0 4px 12px rgba(0,0,0,.1);
  z-index: 20;
  min-width: 120px;
  padding: 4px 0;
  margin-top: 2px;
}

.sidebar-context-menu button {
  display: block;
  width: 100%;
  padding: 8px 14px;
  border: none;
  background: transparent;
  text-align: left;
  font-size: 13px;
  color: #1e293b;
  cursor: pointer;
}

.sidebar-context-menu button:hover {
  background: #f1f5f9;
}

.sidebar-context-menu button.text-danger {
  color: #dc2626;
}

/* =========================================================
   Modal
   ========================================================= */

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  background: #fff;
  border-radius: 12px;
  padding: 24px;
  width: 100%;
  max-width: 440px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.modal-header h3 {
  font-size: 18px;
  font-weight: 700;
  color: #0f172a;
}

.modal-close {
  border: none;
  background: transparent;
  font-size: 22px;
  color: #94a3b8;
  cursor: pointer;
  padding: 2px 6px;
  border-radius: 4px;
}

.modal-close:hover {
  color: #475569;
  background: #f1f5f9;
}

/* =========================================================
   Confirm Modal
   ========================================================= */

.confirm-modal {
  background: #fff;
  border-radius: 16px;
  padding: 32px;
  width: 100%;
  max-width: 400px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
  text-align: center;
  animation: confirmSlideIn 0.2s ease-out;
}

@keyframes confirmSlideIn {
  from { opacity: 0; transform: scale(0.95) translateY(-10px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

.confirm-modal-icon {
  margin-bottom: 16px;
}

.confirm-icon-danger {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #fef2f2;
  color: #dc2626;
  font-size: 24px;
}

.confirm-icon-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #eff6ff;
  color: #2563eb;
  font-size: 24px;
}

.confirm-modal-title {
  font-size: 18px;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8px;
}

.confirm-modal-message {
  font-size: 14px;
  color: #64748b;
  line-height: 1.5;
  margin-bottom: 24px;
}

.confirm-modal-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
}

.confirm-modal-actions .btn {
  min-width: 100px;
}

/* =========================================================
   Invitation Banner
   ========================================================= */

.invitation-banner {
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 16px;
}

.invitation-banner h4 {
  font-size: 14px;
  font-weight: 700;
  color: #1e40af;
  margin-bottom: 10px;
}

.invitation-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 8px 0;
  font-size: 13px;
  color: #1e293b;
  flex-wrap: wrap;
}

.invitation-row + .invitation-row {
  border-top: 1px solid #dbeafe;
}

.invitation-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

/* =========================================================
   Team Cards
   ========================================================= */

.team-card {
  overflow: hidden;
}

.team-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0;
  cursor: pointer;
  gap: 12px;
}

.team-card-header:hover {
  opacity: 0.9;
}

.team-card-body {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid #f1f5f9;
}

.team-members-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.team-member-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 0;
  font-size: 13px;
  color: #1e293b;
}

.team-member-row + .team-member-row {
  border-top: 1px solid #f8fafc;
}

/* =========================================================
   Mock Detail Page
   ========================================================= */

.mock-detail-page {
  max-width: 960px;
}

.mock-detail-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 24px;
}

.mock-detail-header-left {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.mock-detail-title-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.mock-detail-name {
  font-size: 22px;
  font-weight: 700;
  color: #0f172a;
}

.mock-detail-path {
  font-size: 13px;
  padding: 4px 10px;
  background: #f1f5f9;
  border-radius: 4px;
  display: inline-block;
}

.mock-detail-header-right {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
  padding-top: 4px;
}

/* Tabs */
.mock-tabs {
  display: flex;
  gap: 0;
  border-bottom: 2px solid #e2e8f0;
  margin-bottom: 24px;
}

.mock-tab {
  padding: 10px 20px;
  border: none;
  background: none;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  color: #64748b;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  transition: color 0.15s, border-color 0.15s;
}

.mock-tab:hover {
  color: #1e293b;
}

.mock-tab-active {
  color: #2563eb;
  border-bottom-color: #2563eb;
}

.mock-tab-content {
  animation: fadeIn 0.15s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* =========================================================
   Overview Tab
   ========================================================= */

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 16px;
}

.overview-card-title {
  font-size: 14px;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 1px solid #f1f5f9;
}

.overview-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6px 0;
}

.overview-field + .overview-field {
  border-top: 1px solid #f8fafc;
}

.overview-label {
  font-size: 12px;
  color: #64748b;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.overview-value {
  font-size: 13px;
  color: #1e293b;
  font-weight: 500;
}

.overview-url {
  font-size: 12px;
  word-break: break-all;
}

.overview-section {
  margin-bottom: 16px;
}

/* Headers list (shared) */
.headers-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.header-row {
  display: flex;
  gap: 12px;
  padding: 4px 0;
  font-size: 12px;
  align-items: center;
}

.header-row + .header-row {
  border-top: 1px solid #f8fafc;
}

.header-key {
  font-weight: 600;
  color: #6d28d9;
  min-width: 140px;
}

.header-value {
  color: #475569;
  word-break: break-all;
}

/* Code block */
.code-block {
  background: #0f172a;
  color: #e2e8f0;
  padding: 16px;
  border-radius: 8px;
  font-family: 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', monospace;
  font-size: 12px;
  line-height: 1.6;
  overflow-x: auto;
  white-space: pre-wrap;
  word-break: break-word;
  max-height: 400px;
  overflow-y: auto;
}

.code-block-sm {
  max-height: 200px;
  padding: 12px;
}

/* =========================================================
   Scenarios Tab
   ========================================================= */

.scenarios-intro {
  font-size: 13px;
  color: #64748b;
  margin-bottom: 16px;
}

.scenario-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.scenario-card {
  padding: 20px;
}

.scenario-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.scenario-card-title {
  display: flex;
  align-items: center;
  gap: 10px;
}

.scenario-index {
  font-size: 11px;
  font-weight: 700;
  color: #94a3b8;
}

.scenario-priority {
  font-size: 11px;
  color: #94a3b8;
  font-weight: 500;
  background: #f1f5f9;
  padding: 2px 8px;
  border-radius: 4px;
}

.scenario-meta {
  font-size: 12px;
  color: #64748b;
  margin-bottom: 12px;
}

.scenario-section-label {
  font-size: 11px;
  font-weight: 700;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  display: block;
  margin-bottom: 8px;
}

.scenario-conditions {
  margin-bottom: 12px;
}

.condition-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.condition-chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #f1f5f9;
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px;
  border: 1px solid #e2e8f0;
}

.condition-type {
  font-weight: 700;
  color: #2563eb;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.condition-field {
  color: #6d28d9;
  font-weight: 600;
}

.condition-op {
  color: #64748b;
  font-weight: 500;
}

.condition-value {
  color: #15803d;
  font-weight: 600;
}

.scenario-headers {
  margin-bottom: 12px;
}

.scenario-response {
  margin-top: 4px;
}

/* =========================================================
   API Docs Tab
   ========================================================= */

.api-docs-info {
  margin-bottom: 16px;
}

.api-docs-info-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
}

.api-docs-info h3 {
  font-size: 16px;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 4px;
}

.api-docs-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

.api-docs-endpoint {
  margin-bottom: 16px;
  padding: 20px;
}

.api-docs-endpoint-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}

.api-docs-endpoint-header code {
  font-size: 14px;
  font-weight: 600;
  color: #1e293b;
  background: none;
  padding: 0;
}

.api-docs-summary {
  font-size: 13px;
  color: #64748b;
  margin-bottom: 16px;
}

.api-docs-section {
  margin-top: 16px;
}

.api-docs-section h4 {
  font-size: 12px;
  font-weight: 700;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: 8px;
}

.api-docs-params-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

.api-docs-params-table th {
  background: #f8fafc;
  padding: 6px 10px;
  text-align: left;
  font-size: 11px;
  font-weight: 700;
  color: #64748b;
  border-bottom: 1px solid #e2e8f0;
}

.api-docs-params-table td {
  padding: 6px 10px;
  border-bottom: 1px solid #f1f5f9;
}

.api-docs-response {
  margin-bottom: 12px;
}

.api-docs-response-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.api-docs-raw {
  margin-top: 24px;
}

.api-docs-raw h4 {
  font-size: 12px;
  font-weight: 700;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: 8px;
}

/* =========================================================
   Code Snippets Tab
   ========================================================= */

.snippets-intro {
  font-size: 13px;
  color: #64748b;
  margin-bottom: 16px;
}

.snippets-lang-bar {
  display: flex;
  gap: 0;
  background: #f1f5f9;
  border-radius: 8px;
  padding: 4px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.snippets-lang-btn {
  padding: 7px 14px;
  border: none;
  background: none;
  cursor: pointer;
  font-size: 12px;
  font-weight: 600;
  color: #64748b;
  border-radius: 6px;
  transition: all 0.15s;
}

.snippets-lang-btn:hover {
  color: #1e293b;
}

.snippets-lang-active {
  background: #fff;
  color: #2563eb;
  box-shadow: 0 1px 3px rgba(0,0,0,.08);
}

.snippets-code-wrapper {
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,.06), 0 0 0 1px rgba(0,0,0,.04);
}

.snippets-code-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  background: #1e293b;
  color: #94a3b8;
  font-size: 12px;
  font-weight: 600;
}

.snippets-code {
  border-radius: 0;
  margin: 0;
  max-height: 500px;
}

/* =========================================================
   Try It Tab
   ========================================================= */

.tryit-request-card {
  margin-bottom: 16px;
}

.tryit-endpoint-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid #f1f5f9;
}

.tryit-url {
  flex: 1;
  font-size: 14px;
  font-weight: 600;
  color: #1e293b;
  background: #f8fafc;
  padding: 6px 12px;
  border-radius: 6px;
}

.tryit-section {
  margin-bottom: 16px;
}

.tryit-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.tryit-section h4 {
  font-size: 12px;
  font-weight: 700;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: 8px;
}

.tryit-section-header h4 {
  margin-bottom: 0;
}

.tryit-param-row {
  display: flex;
  gap: 8px;
  margin-bottom: 6px;
}

.tryit-param-row input {
  flex: 1;
  padding: 7px 10px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 13px;
  font-family: 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', monospace;
  outline: none;
  transition: border-color 0.15s;
}

.tryit-param-row input:focus {
  border-color: #2563eb;
  box-shadow: 0 0 0 2px rgba(37,99,235,.1);
}

.tryit-body-editor {
  width: 100%;
  padding: 12px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 13px;
  font-family: 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', monospace;
  line-height: 1.6;
  resize: vertical;
  outline: none;
  transition: border-color 0.15s;
}

.tryit-body-editor:focus {
  border-color: #2563eb;
  box-shadow: 0 0 0 2px rgba(37,99,235,.1);
}

.tryit-response-card {
  animation: fadeIn 0.2s ease;
}

.tryit-response-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f1f5f9;
}

.tryit-response-header h3 {
  font-size: 15px;
  font-weight: 700;
  color: #0f172a;
}

.tryit-response-meta {
  display: flex;
  align-items: center;
  gap: 12px;
}

.tryit-response-section {
  margin-bottom: 16px;
}

.tryit-response-section h4 {
  font-size: 11px;
  font-weight: 700;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: 8px;
}

/* =========================================================
   Responsive – Mock Detail
   ========================================================= */

@media (max-width: 640px) {
  .overview-grid {
    grid-template-columns: 1fr;
  }
  .mock-detail-header {
    flex-direction: column;
  }
  .snippets-lang-bar {
    overflow-x: auto;
  }
}

/* ============================================================
   Auth Configuration
   ============================================================ */

.auth-config-section {
  background: var(--bg-secondary, #f8fafc);
  border: 1px solid var(--border, #e2e8f0);
  border-radius: 8px;
  padding: 16px;
  margin-top: 8px;
}

.auth-fields-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 12px;
  margin-top: 8px;
}

.oauth-info-box {
  margin-top: 12px;
  padding: 12px 16px;
  background: var(--bg-tertiary, #f0f4f8);
  border: 1px solid var(--border, #e2e8f0);
  border-radius: 6px;
}

.oauth-info-title {
  font-weight: 600;
  font-size: 13px;
  margin-bottom: 6px;
  color: var(--text-primary, #1e293b);
}

.oauth-info-subtitle {
  font-size: 12px;
  font-weight: 600;
  margin-top: 10px;
  margin-bottom: 4px;
  color: var(--text-secondary, #64748b);
}

.oauth-endpoint-url {
  display: inline-block;
  padding: 4px 10px;
  background: var(--bg-primary, #fff);
  border: 1px solid var(--border, #e2e8f0);
  border-radius: 4px;
  font-size: 12px;
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  color: var(--accent, #6366f1);
}

.oauth-curl-example {
  padding: 8px 12px;
  background: #1e293b;
  color: #e2e8f0;
  border-radius: 6px;
  font-size: 11px;
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  overflow-x: auto;
  white-space: pre;
  margin: 0;
}

.auth-type-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.5px;
  background: var(--accent, #6366f1);
  color: #fff;
}
